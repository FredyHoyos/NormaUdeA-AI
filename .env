# Identidad de la aplicacion
APP_NAME=Copiloto Administrativo Agéntico UdeA

# Rutas base de datos y documentos
DATA_DIR=data
PDF_DIR=data/pdfs
CHROMA_DIR=data/chroma
CHROMA_COLLECTION=udea_documents

# Parametros de segmentacion y recuperacion
CHUNK_SIZE=900
CHUNK_OVERLAP=180
RETRIEVAL_K=5
MAX_CONTEXT_CHARS=12000
CONFIDENCE_THRESHOLD=0.35

# Proveedor LLM
# auto: detecta Ollama local y, si no existe, intenta APIs configuradas
# ollama/openai/gemini: fuerza proveedor especifico
# none: modo contingencia sin llamadas a LLM
LLM_PROVIDER=auto

# OpenAI (solo si LLM_PROVIDER=openai o auto con clave disponible)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini (solo si LLM_PROVIDER=gemini o auto con clave disponible)
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-2.0-flash

# Ollama local (recomendado para uso sin API keys)
# OLLAMA_MODEL_CANDIDATES: lista de modelos de respaldo separados por coma
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_MODEL_CANDIDATES=llama3.1:8b,qwen2.5:7b,mistral:7b
OLLAMA_TIMEOUT_SECONDS=120

# Generacion
TEMPERATURE=0.1

# Embeddings BGE-M3
# local-hash-384 evita descargas y reduce uso de memoria
BGE_M3_MODEL=local-hash-384
BGE_M3_LOCAL_DIR=data/models/bge-m3
BGE_M3_CACHE_DIR=data/models/.cache/huggingface

# OCR para PDFs escaneados
OCR_ENABLED=true
OCR_LANG=eng
OCR_TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe