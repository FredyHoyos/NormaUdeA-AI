# Identidad de la aplicacion
APP_NAME=Copiloto Administrativo Agéntico UdeA

# Rutas base de datos y documentos
DATA_DIR=data
PDF_DIR=data/pdfs
CHROMA_DIR=data/chroma
CHROMA_COLLECTION=udea_documents

# Parametros de segmentacion y recuperacion
CHUNK_SIZE=900
CHUNK_OVERLAP=180
RETRIEVAL_K=5
MAX_CONTEXT_CHARS=12000
CONFIDENCE_THRESHOLD=0.35

# Proveedor LLM
# auto: detecta Ollama local y, si no existe, intenta APIs configuradas
# ollama/openai/gemini: fuerza proveedor especifico
# none: modo contingencia sin llamadas a LLM
LLM_PROVIDER=auto

# OpenAI/OpenAI-compatible (LM Studio)
# Para LM Studio: LLM_PROVIDER=openai, OPENAI_BASE_URL=http://localhost:1234/v1, OPENAI_API_KEY=lm-studio
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Gemini (solo si LLM_PROVIDER=gemini o auto con clave disponible)
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-2.0-flash

# Ollama local (recomendado para uso sin API keys)
# OLLAMA_MODEL_CANDIDATES: lista de modelos de respaldo separados por coma
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_MODEL_CANDIDATES=llama3.1:8b,qwen2.5:7b,mistral:7b
OLLAMA_TIMEOUT_SECONDS=120

# Generacion
TEMPERATURE=0.1

# Embeddings BGE-M3
# Usar BAAI/bge-m3 (multilingual, 1024-dim) o local-hash-384 (sin descargas)
BGE_M3_MODEL=BAAI/bge-m3
BGE_M3_LOCAL_DIR=data/models/bge-m3
BGE_M3_CACHE_DIR=data/models/.cache/huggingface

# Re-ranker (cross-encoder para mejorar relevancia de recuperacion)
RERANKER_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_RETRIEVAL_K=20
RERANKER_FINAL_K=5
RERANKER_USE_LLM_FALLBACK=true

# OCR para PDFs escaneados
OCR_ENABLED=true
OCR_LANG=spa
OCR_TESSERACT_CMD=tesseract


#Ulas es lo que ahora se llama creditos.
