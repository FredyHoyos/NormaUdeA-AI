APP_NAME=Copiloto Administrativo Agéntico UdeA
DATA_DIR=data
PDF_DIR=data/pdfs
CHROMA_DIR=data/chroma
CHROMA_COLLECTION=udea_documents
CHUNK_SIZE=900
CHUNK_OVERLAP=180
RETRIEVAL_K=5
MAX_CONTEXT_CHARS=12000
CONFIDENCE_THRESHOLD=0.35
LLM_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_MODEL_CANDIDATES=llama3.1:8b,qwen2.5:7b,mistral:7b
OLLAMA_TIMEOUT_SECONDS=120
TEMPERATURE=0.1
BGE_M3_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# El mejor modelo BGE_M3_MODEL=BAAI/bge-m3
BGE_M3_CACHE_DIR=data/models/.cache/huggingface